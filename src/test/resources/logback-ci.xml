<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="LOG_PATTERN" value="%d{HH:mm:ss.SSS} [%-5level] %logger{36} - %msg%n" />

    <!-- Console uniquement en CI -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

    <logger name="com.e2e.erudaxis" level="INFO" />
    <logger name="io.github.bonigarcia.wdm" level="ERROR" />
    <logger name="org.openqa.selenium" level="ERROR" />
</configuration>