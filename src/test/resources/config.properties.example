# ERUDAXIS TEST AUTOMATION CONFIGURATION
# Copy this file to config.properties for local usage,
# or rely on environment variables in CI.

base.url=https://staging.erudaxis.com/
browser=chrome
timeout.seconds=15
headless=false
dashboard.timeout.seconds=30

login.email=${LOGIN_EMAIL}
login.password=${LOGIN_PASSWORD}
login.department=${LOGIN_DEPARTMENT}